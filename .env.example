# Nansen API key for on-chain analytics
NANSEN_API_KEY=

# Agent EOA private key (used to sign txs / control smart account)
AGENT_PRIVATE_KEY=

# Agent wallet address (smart account or EOA address)
AGENT_WALLET_ADDRESS=

# Maximum spend per action in ETH
MAX_SPEND_ETH=0.001

# Base mainnet RPC URL
RPC_URL=

# Browser-safe Base RPC URL for wallet balance reads
VITE_BASE_RPC_URL=

# Reown / WalletConnect project ID for the wallet modal
VITE_WALLETCONNECT_PROJECT_ID=

# Optional production Postgres connection string for users, sessions, scan history, and request logs
DATABASE_URL=
# POSTGRES_URL=

# Virtuals ACP builder code
ACP_BUILDER_CODE=

# Virtuals ACP entity ID
ACP_ENTITY_ID=1

# Local API server port
API_PORT=3001
